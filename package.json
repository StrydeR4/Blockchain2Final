{
  "name": "gamefi-economy-protocol",
  "version": "0.1.0",
  "private": true,
  "description": "Blockchain Technologies 2 final project: GameFi Economy protocol with ERC-1155 items, resource AMM, rentals, Chainlink VRF, DAO governance, subgraph, and frontend.",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "lint": "npm run lint:sol && npm run lint:web",
    "lint:sol": "solhint \"contracts/**/*.sol\"",
    "lint:web": "prettier --check \"{frontend,subgraph,script,test,docs}/**/*.{ts,tsx,js,json,md,graphql,yaml,yml}\"",
    "format": "prettier --write \"{frontend,subgraph,script,test,docs}/**/*.{ts,tsx,js,json,md,graphql,yaml,yml}\"",
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "subgraph:codegen": "graph codegen subgraph/subgraph.yaml",
    "subgraph:build": "graph build subgraph/subgraph.yaml"
  },
  "dependencies": {
    "@chainlink/contracts": "^1.3.0",
    "@openzeppelin/contracts": "^5.3.0",
    "@openzeppelin/contracts-upgradeable": "^5.3.0",
    "@tanstack/react-query": "^5.76.1",
    "@wagmi/core": "^2.17.2",
    "graphql-request": "^7.1.2",
    "viem": "^2.30.0",
    "vite": "^6.3.5",
    "wagmi": "^2.15.4"
  },
  "devDependencies": {
    "@graphprotocol/graph-cli": "^0.97.1",
    "@graphprotocol/graph-ts": "^0.37.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-verify": "^2.0.14",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/hardhat-upgrades": "^3.9.0",
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "hardhat": "^2.24.0",
    "hardhat-gas-reporter": "^1.0.10",
    "prettier": "^3.5.3",
    "prettier-plugin-solidity": "^1.4.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "solhint": "^5.0.5",
    "typescript": "^5.8.3"
  }
}
